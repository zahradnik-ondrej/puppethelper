{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "declaration": true,
  },
  "include": ["src/**/*.ts", "index.ts"],
  "exclude": ["node_modules"],
  "types": "dist/index.d.ts"
}
